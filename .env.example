PORTAL_SECRET=replace-with-a-secure-secret
PORTAL_DB=sqlite:///portal.db
PORTAL_TMP=/tmp/autodock_prep
PORTAL_MAX_RECEPTORS=5
PORTAL_ENV_LINE=source /path/to/conda.sh && conda activate vina_env
PORTAL_PUBLIC_EMAIL=public@autodock.local

PUBLIC_MODE=true
ENABLE_AUTH=false
ENABLE_LSF_PACKAGE=false
DEFAULT_PACKAGE_MODE=portable
