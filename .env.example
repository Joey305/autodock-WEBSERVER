# Flask secret key used for session signing.
PORTAL_SECRET=replace-with-a-long-random-secret

# SQLAlchemy database URL. The app defaults to SQLite.
PORTAL_DB=sqlite:///portal.db

# Local workspace directory used for uploaded receptors, ligands, and generated packages.
PORTAL_TMP=/tmp/autodock_prep

# Maximum number of receptors allowed in the UI at once.
PORTAL_MAX_RECEPTORS=5

# Optional shell line injected into generated LSF scripts.
PORTAL_ENV_LINE=source /path/to/conda.sh && conda activate vina_env

# Placeholder identity used when the portal runs in public/no-login mode.
PORTAL_PUBLIC_EMAIL=public@autodock.local

# Public portal behavior.
PUBLIC_MODE=true
ENABLE_AUTH=false

# Package-generation options.
ENABLE_LSF_PACKAGE=false
DEFAULT_PACKAGE_MODE=portable
